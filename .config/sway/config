# uConsole sway config
# Screen: 720x1280 physical, rotated 270 → effective 1280x720

set $mod Mod1
set $left h
set $down j
set $up k
set $right l
set $term x-terminal-emulator
set $menu wofi --show drun --allow-images

# --- Output ---
output DSI-2 mode 720x1280 transform 90
output DSI-1 mode 720x1280 transform 90

# --- Input ---
input type:keyboard {
    repeat_delay 300
    repeat_rate 40
    xkb_rules evdev
    xkb_model pc105
    xkb_layout us
}
input type:pointer {
    natural_scroll enabled
}

# --- Idle ---
exec swayidle -w \
    timeout 600 'playerctl status 2>/dev/null | grep -q "^Playing$" || swaylock -f -c 1e1e2e' \
    timeout 610 'playerctl status 2>/dev/null | grep -q "^Playing$" || swaymsg "output * power off"' \
    resume 'swaymsg "output * power on"' \
    before-sleep 'swaylock -f -c 1e1e2e'

# --- Autostart ---
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec /usr/libexec/xdg-desktop-portal

# --- Appearance ---
default_border pixel 2
default_floating_border pixel 2
gaps inner 8
gaps outer 4
smart_gaps on
smart_borders on
font pango:PibotoLt 11

# Catppuccin Mocha colors
set $base    #1e1e2e
set $mantle  #181825
set $surface #313244
set $overlay #6c7086
set $text    #cdd6f4
set $lavender #b4befe
set $blue    #89b4fa
set $pink    #f38ba8

# class                 border    bg        text    indicator  child_border
client.focused          $lavender $lavender $base   $pink      $lavender
client.focused_inactive $surface  $surface  $text   $overlay   $surface
client.unfocused        $base     $base     $overlay $base     $base
client.urgent           $pink     $pink     $text   $pink      $pink

# --- Key bindings ---
bindsym $mod+Return exec $term
bindsym $mod+space exec $menu
bindsym $mod+q kill
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning -m 'Exit sway?' -B 'Yes, exit' 'swaymsg exit'

# Focus (vim + arrows)
bindsym $mod+$left  focus left
bindsym $mod+$down  focus down
bindsym $mod+$up    focus up
bindsym $mod+$right focus right
bindsym $mod+Left   focus left
bindsym $mod+Down   focus down
bindsym $mod+Up     focus up
bindsym $mod+Right  focus right

# Move
bindsym $mod+Shift+$left  move left
bindsym $mod+Shift+$down  move down
bindsym $mod+Shift+$up    move up
bindsym $mod+Shift+$right move right
bindsym $mod+Shift+Left   move left
bindsym $mod+Shift+Down   move down
bindsym $mod+Shift+Up     move up
bindsym $mod+Shift+Right  move right

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5

# Workspace navigation
bindsym $mod+Tab         workspace next
bindsym $mod+Shift+Tab  workspace prev

# Layout
bindsym $mod+b         splith
bindsym $mod+v         splitv
bindsym $mod+s         layout stacking
bindsym $mod+w         layout tabbed
bindsym $mod+e         layout toggle split
bindsym $mod+f         fullscreen toggle
bindsym $mod+Shift+f   floating toggle
bindsym $mod+a         focus parent
bindsym $mod+d         focus child

# Resize mode
mode "resize" {
    bindsym $left  resize shrink width  20px
    bindsym $right resize grow   width  20px
    bindsym $up    resize shrink height 20px
    bindsym $down  resize grow   height 20px
    bindsym Left   resize shrink width  20px
    bindsym Right  resize grow   width  20px
    bindsym Up     resize shrink height 20px
    bindsym Down   resize grow   height 20px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Scratchpad
bindsym $mod+minus       scratchpad show
bindsym $mod+Shift+minus move scratchpad

# Volume handled by uconsole-volume daemon (speaker + up/down arrows)
# Mute toggle on speaker + Fn is handled in the daemon
bindcode --locked 121 exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

# Brightness
bindsym XF86MonBrightnessUp   exec rpi-backlight up
bindsym XF86MonBrightnessDown exec rpi-backlight down

# Screenshot (requires grim + slurp + wl-clipboard)
bindsym $mod+Print       exec grim ~/Screenshots/$(date +%Y%m%d_%H%M%S).png
bindsym $mod+Shift+Print exec grim -g "$(slurp)" ~/Screenshots/$(date +%Y%m%d_%H%M%S).png

# --- Window rules ---
for_window [app_id="proton.vpn.app.gtk"] move scratchpad
for_window [app_id="vlc"]     inhibit_idle visible
for_window [app_id="mpv"]     inhibit_idle visible
for_window [app_id="firefox"] inhibit_idle fullscreen

# --- Status bar ---
bar {
    swaybar_command waybar
}
